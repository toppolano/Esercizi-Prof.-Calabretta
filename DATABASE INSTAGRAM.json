*DATABASE INSTAGRAM*
CREATE (:Persona {nome: "Anna"})
CREATE (:Persona {nome: "Luca"})
CREATE (:Persona {nome: "Marco"})
CREATE (:Persona {nome: "Giulia"})
CREATE (:Persona {nome: "Elena"})


"ANNA SEGUE LUCA E MARCO"
MATCH (anna:Persona {nome: "Anna"})
MATCH (luca:Persona {nome: "Luca"})
MATCH (marco:Persona {nome: "Marco"})
MERGE (anna)-[:SEGUE]->(luca)
MERGE (anna)-[:SEGUE]->(marco)

"MARCO SEGUE ANNA"
MATCH (anna:Persona {nome: "Anna"})
MATCH (marco:Persona {nome: "Marco"})
MERGE (marco)-[:SEGUE]->(anna)

"GIULIA SEGUE TUTTI"
MATCH (anna:Persona {nome: "Anna"})
MATCH (luca:Persona {nome: "Luca"})
MATCH (marco:Persona {nome: "Marco"})
MATCH (giulia:Persona {nome: "Giulia"})
MATCH (elena:Persona {nome: "Elena"})
MERGE (giulia)-[:SEGUE]->(anna)
MERGE (giulia)-[:SEGUE]->(luca)
MERGE (giulia)-[:SEGUE]->(marco)
MERGE (giulia)-[:SEGUE]->(elena)

"MOSTRARE MATCH Tutti gli utenti con il numero di follower maggiore di 1"
MATCH (follower:Persona)-[:SEGUE]->(utente:Persona)
WITH utente, count(follower) AS numero_follower
WHERE numero_follower > 1
RETURN utente.nome AS Utente

"MOSTRARE CHI NON SEGUE NESSUNO"
MATCH (p:Persona)
WHERE NOT (p)-[:SEGUE]->()
RETURN p


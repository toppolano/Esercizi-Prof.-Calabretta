*DATABASE FACEBOOK*
CREATE (:Persona {nome: "Alice"})
CREATE (:Persona {nome: "Bob"})
CREATE (:Persona {nome: "Carol"})
CREATE (:Persona {nome: "Dan"})

"Alice ↔ Bob"
MATCH (alice:Persona {nome: "Alice"})
MATCH (bob:Persona {nome: "Bob"})
MERGE (alice)-[:AMICO]->(bob)
MERGE (bob)-[:AMICO]->(alice)

"Alice ↔ Carol"
MATCH (alice:Persona {nome: "Alice"})
MATCH (carol:Persona {nome: "Carol"})
MERGE (carol)-[:AMICO]->(alice)
MERGE (alice)-[:AMICO]->(carol)

"Bob ↔ Dan"
MATCH (bob:Persona {nome: "Bob"})
MATCH (dan:Persona {nome: "Dan"})
MERGE (bob)-[:AMICO]->(dan)
MERGE (dan)-[:AMICO]->(bob)

"Scrivi una query che restituisca tutte le coppie di amici, mostrando ogni relazione una sola volta."
MATCH (p1:Persona)-[:AMICO]->(p2:Persona)
WHERE p1.nome < p2.nome
RETURN p1.nome AS Amico1, p2.nome AS Amico2

"Esempio query profonda"
MATCH percorso = (p1:Persona)-[:AMICO*2]-(p2:Persona)
WHERE p1.nome < p2.nome 
  AND NOT (p1)-[:AMICO]-(p2)
RETURN percorso
